# Copy to .env (which is gitignored) and fill in your sandbox details.
# A classic PAT with `repo` scope works, or a fine-grained token with:
#   - Pull requests: Read+Write
#   - Contents:      Read
#   - Checks:        Write
GITHUB_TOKEN=ghp_replace_me

# Format: owner/repo
DRIFT_SANDBOX_REPO=your-user/drift-sandbox

# An open PR you want the smoke run to post against.
DRIFT_SANDBOX_PR=1

# The head SHA of that PR (run `git rev-parse HEAD` in your sandbox PR branch).
# Required for the inline-review comments — GitHub rejects suggestions whose
# commit_id doesn't match the PR's latest commit.
DRIFT_SANDBOX_HEAD_SHA=replace_me_40_char_sha
