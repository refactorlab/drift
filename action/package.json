{
  "name": "@drift/action",
  "version": "0.1.0",
  "private": true,
  "description": "Drift GitHub Action runner",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=../dist/index.js",
    "test": "node --test --experimental-strip-types --no-warnings 'src/__tests__/*.test.ts'",
    "smoke": "./scripts/smoke.sh",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1"
  }
}
