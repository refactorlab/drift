{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "bunVersion": "1.x",
  "buildCommand": "bun run build && bun run migrate",
  "installCommand": "bun install",
  "functions": {
    "api/index.ts": {
      "includeFiles": "{web/dist/**,db.sqlite}"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/healthcheck", "destination": "/api" },
    { "source": "/openapi", "destination": "/api" },
    { "source": "/docs", "destination": "/api" },
    { "source": "/(.*)", "destination": "/api" }
  ]
}
