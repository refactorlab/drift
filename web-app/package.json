{
  "name": "drift",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"bun run dev:api\" \"bun run dev:web\"",
    "dev:api": "bun run --hot src/index.ts",
    "dev:web": "cd web && bun run dev",
    "build": "cd web && bun run build",
    "start": "bun run src/index.ts",
    "migrate": "bun run src/migrate.ts"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.3.0",
    "hono": "^4.9.12",
    "hono-openapi": "^1.3.0",
    "zod": "^3.23.0",
    "zod-openapi": "npm:zod-openapi@^4.2.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "concurrently": "^9.0.0"
  }
}
