# --- Database ---
# Leave DATABASE_URL unset (or non-postgres://) to use a local SQLite file.
# Set it to a postgres:// URL to use Postgres (e.g. Neon, Supabase, Railway).
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Local SQLite path (only used when DATABASE_URL is not a postgres URL).
# SQLITE_PATH=./db.sqlite

# --- Server ---
PORT=8000

# --- Admin seed ---
ADMIN_EMAIL=admin@drift.local
ADMIN_PASSWORD=1234

# --- Auth ---
# JWT_SECRET=change-me-in-production
