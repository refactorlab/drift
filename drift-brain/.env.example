# drift-brain config (all optional). Copy to .env — Bun auto-loads it.
# Auth uses your `claude login` — NO API key here.

# Model for the voice brain. Default: claude-opus-4-8.
# For lower spoken-turn latency, try claude-sonnet-4-6 or claude-haiku-4-5.
ANTHROPIC_MODEL=claude-opus-4-8

# Loopback port the extension calls. Default: 8787.
PORT=8787
