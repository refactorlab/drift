{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "dialog:default",
    "dialog:allow-open",
    "opener:default",
    "opener:allow-open-url",
    "store:default",
    "window-state:default",
    "updater:default",
    "process:default"
  ]
}
