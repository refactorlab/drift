{
  "name": "drift-chrome-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Andy — an AI PR-review assistant that opens in a Chrome side panel on any GitHub pull request, with the PR's scan context attached, so you can chat about the change.",
  "scripts": {
    "icons": "node scripts/generate-icons.mjs",
    "stage:ort": "node scripts/stage-ort.mjs",
    "dev": "npm run icons && npm run stage:ort && vite",
    "build": "npm run icons && npm run stage:ort && tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "scan": "vite-node src/cli/run.ts --",
    "test": "vitest run",
    "verify:assets": "node scripts/verify-assets.mjs",
    "verify:store": "node scripts/verify-store-build.mjs",
    "zip": "DRIFT_STORE_BUILD=1 npm run build && npm run verify:assets && npm run verify:store && node scripts/zip.mjs",
    "store-assets": "node scripts/generate-store-assets.mjs",
    "prepare:assets": "npm run build:wasm && npm run build:tts",
    "build:wasm": "bash scripts/build-wasm.sh",
    "build:tts": "node scripts/stage-ort.mjs"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "@mlc-ai/web-llm": "^0.2.84",
    "fflate": "^0.8.3",
    "js-tiktoken": "^1.0.21",
    "kokoro-js": "^1.2.1",
    "marked": "^14.1.4",
    "mermaid": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^6.4.2",
    "vitest": "^2.1.9"
  }
}
