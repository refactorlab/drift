{
  "name": "drift-chrome-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Andy — an AI PR-review assistant that opens in a Chrome side panel on any GitHub pull request, with the PR's scan context attached, so you can chat about the change.",
  "scripts": {
    "icons": "node scripts/generate-icons.mjs",
    "dev": "npm run icons && vite",
    "build": "npm run icons && tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "zip": "npm run build && node scripts/zip.mjs",
    "store-assets": "node scripts/generate-store-assets.mjs"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "marked": "^14.1.4",
    "typescript": "^5.6.3",
    "vite": "^6.4.2",
    "vitest": "^2.1.9"
  }
}
