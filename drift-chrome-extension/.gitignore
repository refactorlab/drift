node_modules/
dist/
release/
public/icons/
*.log
.DS_Store
# Local-only CWS publish credentials — these belong in GitHub repo secrets, never in git.
.env
.env.*
# WASM scanner build product (regenerate via scripts/build-wasm.sh)
public/drift-static-profiler.wasm
public/drift-scanner.meta.json
# Rust build artifacts for the in-repo wasm crates (e.g. crates/volley-core/target,
# ~43 MB). The SOURCE (src/*.rs, Cargo.toml, Cargo.lock) and the committed wasm-pack
# output (src/vendor/volley/*) ARE tracked; only target/ is regenerated.
crates/**/target/
# wasm-pack leftovers in the vendored output dir. Every build of the voice FSM
# (scripts/build-voice-wasm.sh — and the dev watcher that re-runs it on each Rust
# edit) emits a '*' .gitignore + an npm package.json next to the module; the script
# rm's them on success, but an interrupted/failed rebuild can leave them behind.
# Ignore them so dev hot-reload churn never stages them — the real vendored module
# (volley_core.js / .d.ts / .wasm / .wasm.d.ts / README.md) stays tracked.
src/vendor/volley/.gitignore
src/vendor/volley/package.json
# Kokoro TTS engine assets (large; stage via scripts/build-tts.sh)
public/kokoro/
# onnxruntime-web WASM engine (large; staged from node_modules via scripts/stage-ort.mjs)
public/ort/
# Bundled Kokoro model + meta (large; staged from HF via scripts/stage-kokoro.mjs)
public/models/
public/kokoro.meta.json
