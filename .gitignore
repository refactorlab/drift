action/node_modules/
.DS_Store

# One-shot scratch outputs from `make action-scan-demo` etc. — JSON
# fixtures regenerated locally; never committed.
/tmp/

# Tauri updater signing keys — generated locally by `tauri signer generate`.
# Private key must never be committed. See drift-lab/UPDATER.md.
.tauri-keys/
.tauri-keys.bak.*
# Local production export drop folder written by `make drift-lab-export`.
# Contains built .app/.dmg/.AppImage/.deb + SHA256SUMS — release artifacts
# belong on GitHub Releases, not in git. Exceptions: the GitHub Action
# bundles MUST be tracked — composite actions resolve these from the
# consumer's checkout of refactorlab/drift@<ref>. ai-infer-one.js is the
# per-suggestion inference loop; index/ai-suggest are the review + post
# bundles. (ai-context.js is legacy — no longer called by action.yml.)
/dist/*
!/dist/index.js
!/dist/ai-context.js
!/dist/ai-suggest.js
!/dist/ai-infer-one.js
drift-static-profiler/research/code-production-repositories
drift-static-profiler/research/django-check

# Local environment files — credentials, project URLs, etc. Each
# subproject has a committed `.env.example` showing the shape; the
# real `.env` stays out of git.
.env
**/.env
tmp/