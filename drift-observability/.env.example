# Template — copy to `.env` (gitignored) and fill in real values.
# Loaded by drift-observability/Makefile via `-include .env`.

# Supabase project URL. Format: https://<project-id>.supabase.co
# Find in dashboard: Project Settings → API → Project URL.
SUPABASE_URL=https://<project-id>.supabase.co

# Realtime API key. The publishable key (sb_publishable_...) is the
# new replacement for the old anon JWT and is correct for broadcasting
# on public channels. Do NOT put the service_role key here.
# Find in dashboard: Project Settings → API → Project API Keys → publishable.
SUPABASE_REALTIME_API_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Channel name used by `make live-supabase-driftdockerprofiler`.
SUPABASE_REALTIME_CHANNEL=drift-test
