# dev/Tiltfile — brings up the drift demo on minikube as two independent
# Kubernetes Deployments connected over a ClusterIP Service.
#
#   make up
#
# Once tilt is up:
#   - http://localhost:8000/docs   → FastAPI app   (test-python-web-server)
#   - http://localhost:8080/docs/  → observability-server Swagger UI
#   - http://localhost:8080/live   → live SSE viewer

REPO_ROOT = '..'
NAMESPACE = 'local'

# The shared trace volume on the minikube node is wiped from the Makefile
# (`wipe-trace`, invoked by both `make up` and `make down`) so this Tiltfile
# can be loaded even when the cluster is offline — important so `tilt down`
# is callable from a cold/stopped state without blowing up in `local(...)`.

k8s_yaml(blob("""
apiVersion: v1
kind: Namespace
metadata:
  name: %s
""" % NAMESPACE))

# --- driftdockerprofiler wheel (Dockerized build) -------------------------
# Build the driftdockerprofiler wheel via `make wheel-driftdockerprofiler`,
# which runs `python -m build` inside a python:3.11 sidecar (needs gcc/g++
# because the wheel ships a compiled C++ extension — the SIGPROF CPU
# sampler) and mirrors the .whl to drift-profiler-python/dist/, which
# test-python-web-server's Dockerfile copies from.
#
# Tilt re-fires this when anything under driftdockerprofiler/ or its
# setup.py / C++ sources change — wheel always reflects live source.
local_resource(
    'driftdockerprofiler-wheel',
    cmd='make -C %s wheel-driftdockerprofiler' % REPO_ROOT,
    deps=[
        REPO_ROOT + '/drift-profiler-python/driftdockerprofiler/',
        REPO_ROOT + '/drift-profiler-python/setup.py',
        REPO_ROOT + '/drift-profiler-python/Dockerfile',
    ],
    labels=['drift-demo'],
)

# Sibling wheel build for the python:3.14 image. Same multi-stage
# Dockerfile, just with --build-arg PYTHON_VERSION=3.14 so the
# embedded C++ extension is ABI-locked to cp314. Output goes to a
# distinct directory (dist-py314/) so the cp37 and cp314 wheels don't
# stomp each other — pip can't auto-select between two wheels in the
# same COPY pattern.
local_resource(
    'driftdockerprofiler-wheel-py314',
    cmd=('cd %s/drift-profiler-python' % REPO_ROOT) +
        ' && rm -rf dist-py314 && mkdir -p dist-py314' +
        ' && docker build --build-arg PYTHON_VERSION=3.14' +
        ' --output type=local,dest=./dist-py314' +
        ' --target wheel-export .',
    deps=[
        REPO_ROOT + '/drift-profiler-python/driftdockerprofiler/',
        REPO_ROOT + '/drift-profiler-python/setup.py',
        REPO_ROOT + '/drift-profiler-python/Dockerfile',
    ],
    labels=['drift-demo'],
)

# Supabase env vars for the python:3.14 sibling pod ONLY. The
# python:3.7 image stays file-mode, so we don't touch its Deployment.
#
# Loading order:
#   1. The dev Makefile invokes `tilt up -- --env-file <path>` and the
#      flag is declared below via `config.define_string`. Without that
#      declaration Tilt parses post-`--` args as resource-name filters
#      and errors out with "resources not found".
#   2. The path defaults to drift-observability/.env so a plain
#      `tilt up` (no Make wrapper) also picks up the same file.
#   3. The dotenv extension slurps the file into the Tiltfile process
#      env; os.getenv then pulls the three keys we care about and
#      interpolates them into the py314 manifest below.
#   4. Missing file / missing keys → empty strings →
#      `driftdockerprofiler.from_env()` returns None → file-mode
#      profiler (same behaviour as the python:3.7 image).
#
# https://github.com/tilt-dev/tilt-extensions/tree/master/dotenv
config.define_string(
    'env-file',
    usage='Path to a .env file with SUPABASE_* settings',
)
_cfg = config.parse()
_ENV_FILE_PATH = _cfg.get('env-file', REPO_ROOT + '/.env')

# Guard against dotenv() blowing up on a missing file — read_file with
# default='' tells us cheaply whether to load. We still always load
# the extension; the dotenv call is what's optional.
load('ext://dotenv', 'dotenv')
if str(read_file(_ENV_FILE_PATH, default='')):
    dotenv(fn=_ENV_FILE_PATH)

SUPABASE_URL_VAL     = os.getenv('SUPABASE_URL', '')
SUPABASE_KEY_VAL     = os.getenv('SUPABASE_REALTIME_API_KEY', '')
SUPABASE_CHANNEL_VAL = os.getenv('SUPABASE_REALTIME_CHANNEL', 'drift-test')

# --- Images ----------------------------------------------------------------
# test-python-web-server's Dockerfile consumes the prebuilt wheel from
# drift-profiler-python/dist/ (produced by the driftdockerprofiler-wheel
# resource above) — so its build context is the repo root.
docker_build(
    'test-python-web-server',
    context=REPO_ROOT,
    dockerfile=REPO_ROOT + '/test-python-web-server/Dockerfile',
    only=[
        'drift-profiler-python/dist/',
        'test-python-web-server/',
    ],
)

docker_build(
    'observability-server',
    context=REPO_ROOT + '/observability-server',
    dockerfile=REPO_ROOT + '/observability-server/Dockerfile',
)

# python:3.14 sibling of test-python-web-server. SAME app.py +
# orders.py, different Dockerfile — see
# test-python-web-server/python3.14.Dockerfile for the deltas.
docker_build(
    'test-python-web-server-py314',
    context=REPO_ROOT,
    dockerfile=REPO_ROOT + '/test-python-web-server/python3.14.Dockerfile',
    only=[
        'drift-profiler-python/dist-py314/',
        'test-python-web-server/',
    ],
)

# --- Helm chart ------------------------------------------------------------
k8s_yaml(helm(
    REPO_ROOT + '/deploy/drift-demo',
    name='demo',
    namespace=NAMESPACE,
))

# --- Tilt resources --------------------------------------------------------
# Each Deployment becomes its own Tilt resource. We register them explicitly
# so the sidebar names + port-forwards are clean.
k8s_resource(
    'demo-obs',
    new_name='observability-server',
    port_forwards=[port_forward(8080, 8080, name='obs')],
    labels=['drift-demo'],
)

k8s_resource(
    'demo-app',
    new_name='test-python-web-server',
    port_forwards=[port_forward(8000, 8000, name='app')],
    resource_deps=['observability-server', 'driftdockerprofiler-wheel'],
    labels=['drift-demo'],
)

# --- python:3.14 sibling pod ----------------------------------------------
# Same FastAPI app, different interpreter. Lives outside the Helm chart
# (inline manifest) so an experimental Python version doesn't have to
# round-trip through chart edits. Supabase env vars are interpolated
# from drift-observability/.env (parsed above); missing .env → empty
# strings → file-mode profiler.
k8s_yaml(blob("""
apiVersion: apps/v1
kind: Deployment
metadata:
  name: demo-app-py314
  namespace: %s
  labels:
    app.kubernetes.io/part-of: drift-demo
    app.kubernetes.io/component: app-py314
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/component: app-py314
  template:
    metadata:
      labels:
        app.kubernetes.io/component: app-py314
    spec:
      containers:
        - name: app
          image: test-python-web-server-py314
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: 8000
          env:
            - name: DRIFT_SERVICE
              value: test-python-web-server-py314
            - name: SUPABASE_URL
              value: "%s"
            - name: SUPABASE_REALTIME_API_KEY
              value: "%s"
            - name: SUPABASE_REALTIME_CHANNEL
              value: "%s"
          volumeMounts:
            - name: trace
              mountPath: /trace
          readinessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 5
            periodSeconds: 5
      volumes:
        - name: trace
          hostPath:
            path: /tmp/drift-trace
            type: DirectoryOrCreate
---
apiVersion: v1
kind: Service
metadata:
  name: demo-app-py314
  namespace: %s
spec:
  type: ClusterIP
  ports:
    - name: http
      port: 8000
      targetPort: http
  selector:
    app.kubernetes.io/component: app-py314
""" % (NAMESPACE, SUPABASE_URL_VAL, SUPABASE_KEY_VAL,
        SUPABASE_CHANNEL_VAL, NAMESPACE)))

k8s_resource(
    'demo-app-py314',
    new_name='test-python-web-server-py314',
    port_forwards=[port_forward(8014, 8000, name='app-py314')],
    resource_deps=[
        'observability-server',
        'driftdockerprofiler-wheel-py314',
    ],
    labels=['drift-demo'],
)
